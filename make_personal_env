    perl ./install-tl --paper=letter --texdir=$install_dir --no-interaction
    if [[ $? != 0 ]]; then
        texlive_failed=
    fi

    echo "Un-mounting TexLive ISO" 
    sudo umount /mnt/texlive
    sudo rmdir /mnt/texlive
    if [[ -n $texlive_failed ]]; then
        printf "${RED}Texlive installation failed\n${NOCOLOR}"
