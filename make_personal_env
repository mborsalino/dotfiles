    echo "Mounting TexLive ISO" 
    sudo mkdir -p /mnt/texlive
    sudo mount -t iso9660 -o ro,loop,noauto ./texlive.iso /mnt/texlive
    cd /mnt/texlive
    set +e

    echo "Installing texlive packages (full installation)"
    # Use release date as version, grab it from last line of release notes
    texlive_version=$(tail -1 /mnt/texlive/release-texlive.txt | grep -oP '\d{8}')
