#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NOCOLOR='\033[0m'

log_progress () {
    echo "$(date): $1" >> $tmp/make_sicoe_env_install.log
}

# The following relies on global vars (subset and exclude_texlive)
set_env_vars() {

    if [[ $subset == all ]]; then 
        ENV_MOD=1
        CFG_FILE=1
        RUSTUP=1
        RUST_APPS=1
        MDBOOK=1
        NNN=1
        VIM=1
        NEOVIM=1
        FZF=1
        COPILOT_CLI=1
        PYTHON=1
        DONGLES=1
        SEVENZIP=1
        DOXYGEN=1
        GRAPHVIZ=1
        if [[ $excl_texlive ]]; then
            TEXLIVE=0
        else
            TEXLIVE=1
        fi
        LSUIO=1
        CTAGS=1
        TAR=1
        TIG=1
        GLOW=1
    elif [[ $subset == necessary ]]; then
        ENV_MOD=1
        CFG_FILE=1
        RUSTUP=1
        RUST_APPS=0
        MDBOOK=1
        NNN=0
        VIM=0
        NEOVIM=0
        FZF=0
        COPILOT_CLI=0
        PYTHON=1
        DONGLES=1
        SEVENZIP=1
        DOXYGEN=1
        GRAPHVIZ=0
        if [[ -n $excl_texlive ]]; then
            TEXLIVE=0
        else
            TEXLIVE=1
        fi
        LSUIO=0
        CTAGS=0
        TAR=1
        TIG=0
        GLOW=0
    elif [[ $subset == optional ]]; then
        ENV_MOD=0
        CFG_FILE=0
        RUSTUP=0
        RUST_APPS=1
        MDBOOK=0
        NNN=1
        VIM=1
        NEOVIM=1
        FZF=1
        COPILOT_CLI=1
        PYTHON=0
        DONGLES=0
        SEVENZIP=0
        DOXYGEN=0
        GRAPHVIZ=1
        TEXLIVE=0
        LSUIO=1
        CTAGS=1
        TAR=0
        TIG=1
        GLOW=1
    elif [[ $subset == filter ]]; then
        printf "${CYAN}Using custom set. "
        printf "We trust you took care of setting the appropriate env vars"
        printf "${NOCOLOR}\n"
        [ -z $ENV_MOD ] && ENV_MOD=0
        [ -z $CFG_FILE ] && CFG_FILE=0
        [ -z $RUSTUP ] && RUSTUP=0
        [ -z $RUST_APPS ] && RUST_APPS=0
        [ -z $MDBOOK ] && MDBOOK=0
        [ -z $NNN ] && NNN=0
        [ -z $VIM ] && VIM=0
        [ -z $NEOVIM ] && NEOVIM=0
        [ -z $FZF ] && FZF=0
        [ -z $COPILOT_CLI ] && COPILOT_CLI=0
        [ -z $PYTHON ] && PYTHON=0
        [ -z $DONGLES ] && DONGLES=0
        [ -z $SEVENZIP ] && SEVENZIP=0
        [ -z $DOXYGEN ] && DOXYGEN=0
        [ -z $GRAPHVIZ ] && GRAPHVIZ=0
        [ -z $TEXLIVE ] && TEXLIVE=0
        [ -z $LSUIO ] && LSUIO=0
        [ -z $CTAGS ] && CTAGS=0
        [ -z $TAR ] && TAR=0
        [ -z $TIG ] && TIG=0
        [ -z $GLOW ] && GLOW=0
    else
        printf "${RED} Unrecognized argument to --which${NOCOLOR}\n"
        exit 1
    fi

    # No matter which set was chosen, honor TEXLIVE_LOCAL if defined
    if [[ -z $TEXLIVE_LOCAL ]]; then
        TEXLIVE_LOCAL=0
    fi
}


usage=$( cat<<EOF
make_sicoe_env [-h] --which <set_name> [options]

Build and centrally install all Linux tools used by the SICOE group.

For each tool that is built and installed, a corresponding modulefile
is created. The tool can be brought to the user environment using
module load <toolname>. Use "module avail" to see a list of all available
modules.

The script will automatically detect the running OS. If you're working in an
Network filesystem and access it from different OSes, then you'll have to
run this script once per OS.


Options:

--keep-tmp
    Do not remove temporary files. This is used for debug purposes.

--root <root_dir>
    Mandatory option.
    Ther root dir under which the environment will be installed.
    On Altera labs/farm this must be: /p/psg/swip/w/psg_sicoe

--which <set_name>
    Mandatory option.
    Only build tools in one of the following pre-defined sets:
        necessary
            Build only stuff that is strictly required.
        optional
            Build only optional tools (such as vim, fzf, rust applications etc.)
            This assumes you've run --necessary in the past and everything is
            up to date.
        all
            Build required + optional tools
        filter
            Build only the tools specified by the env vars that are described
            below.

--exclude-texlive
    Requires --which=all or --which=necessary
    TexLive is required by Doxygen to create API docs. Manual installation and
    package downloads is only necessary on Linux distros where we do not have
    control over system-level packages (e.g. the farm).
    On standalone systems (e.g. ubuntu) you can specify this option and install
    a "full" or "recommended" texlive set of system packages using apt/yum.
    * This is not recommended: if doxygen fails no support will be provided *

Any of the following env vars can be set to 1 to only install a custom subset
of the sicoe tools. This is useful when a new tool is added, or one of the
components needs to be updated. 

The environment variables are only honored if --which=filter is specified. They
will be ignored if custom=necessary/optional/all.

ENV_MOD
    Install and configure environment-modules

CFG_FILE
    Install the sbruf.env.bash config file

RUSTUP
    The rust build/install system.

RUST_APPS
    This builds a bunch of utilities written in rust (exa, fd, rg, starship etc.)
    Requires RUSTUP

MDBOOK
    The markdown book generation required by SST (requires RUSTUP)

NNN
    The nnn file manager

VIM
    A very recent version of the Vim editor

NEOVIM
    Neovim 

FZF
    Fuzzy finder

COPILOT_CLI
    The GitHub Copilot CLI

PYTHON
    The Python version required by the SST development

PYTHON_PACKAGES
    All python packages that are required by SST.
    Forced to 1 when PYTHON=1, use it with PYTHON=0 to upgrade to the latest
    package list.

DONGLES
    The USB dongle third-party libs used by SST (Cheetah, Sub20, FTDI, libusb)

SEVENZIP
    The 7z compression utility

DOXYGEN
    Doxygen

GRAPHVIZ
    Graphviz graph visualization tools (dot, neato, etc.)

TEXLIVE
    Texlive

LSUIO
    lsuio utility

CTAGS
    exuberant ctags

TAR
    GNU tar

GLOW
    Terminal markdown renderer (charmbracelet/glow)

The following env var can be used to debug texlive installation:

TEXLIVE_LOCAL
    Default to 0. Set to 1 to avoid downloading Texlive on subsequent runs.
    Used to debug this script, needs --keep-tmp option in conjunction, will
    work with any --which setting.

Examples:
-------
# First-time install on standalone if you have your own set of productivity stuff
make_sicoe_env --root=$HOME/sicoe --which=necessary 

# First-time installation on standalon if you want optional productivity stuff
make_sicoe_env --root=$HOME/sicoe --which=all 

# Installation for newly supported OS on PSG NFS
make_sicoe_env --root=/p/psg/swip/w/psg_sicoe --which=all

# Grap update on config file
CFG_FILE=1 make_sicoe_env --root=$HOME/sicoe --which=filter 

# Grap update on required Python and Python packages
PYTHON=1 PYTHON_PACKAGES=1 make_sicoe_env --root=$HOME/sicoe --which=filter 

EOF
)

# set shell to exit immediately if a pipeline fails
set -e
# use GNU getopt to retrieve option string orig_args=$@
OPTS=`getopt -n $0 -o h -l help,which:,root:,keep-tmp,exclude-texlive -- "$@"`
# set the positional parameters to the ones returned by getopt
eval set -- "$OPTS"

# scan the options
keep_tmp=
subset=
root=
exclude_texlive=
while true
do
    case "$1" in
        -h|--help)
            echo "$usage";
            exit 1
            ;;
        --which)
           subset=$2
           shift 2
           ;;
        --root)
           # strip trailing slash
           root="${2%/}"
           shift 2
           ;;
        --keep-tmp)
           keep_tmp=1
           shift
           ;;
        --exclude-texlive)
           exclude_texlive=1
           shift
           ;;
        --)
            shift
            break
            ;;
    esac
done

# Arg check
if [[ -z $subset ]]; then
    printf "${RED}ERROR: --which is a mandatory option${NOCOLOR}\n"
    exit 1
fi
if [[ -n $exclude_texlive && ($subset == filter || $subset == optional) ]]; then
    printf "${RED}ERROR: --exclude-texlive is ony valid with --which='all' and 'necessary'{NOCOLOR}\n"
    exit 1
fi

# Set all variables that steer the installation
set_env_vars $subset "$exclude_texlive"

# Detect OS
os_rel=$(cat /etc/os-release)
if [[ $os_rel =~ 'NAME="Ubuntu"' && $os_rel =~ 'VERSION_ID="20.04"' ]]; then
    os=ubu20
elif [[ $os_rel =~ 'NAME="Ubuntu"' && $os_rel =~ 'VERSION_ID="22.04"' ]]; then
    os=ubu22
elif [[ $os_rel =~ 'NAME="Ubuntu"' && $os_rel =~ 'VERSION_ID="24.04"' ]]; then
    os=ubu24
elif [[ $os_rel =~ 'NAME="SLES"' && $os_rel =~ 'VERSION_ID="12.5"' ]]; then
    os=suse12
elif [[ $os_rel =~ 'NAME="SLES"' && $os_rel =~ 'VERSION_ID="15.4"' ]]; then
    os=suse15
elif [[ $os_rel =~ 'NAME="Rocky Linux"' && $os_rel =~ 'VERSION_ID="8' ]]; then
    os=rocky8
elif [[ $os_rel =~ 'NAME="Red Hat Enterprise Linux"' && $os_rel =~ 'VERSION_ID="8.4"' ]]; then
    os=rhl8
else
    printf "${RED}ERROR: unsupported OS: $os_rel${NOCOLOR}\n"
    exit 1
fi

if [ -z $root ]; then
    echo "ERROR: --root is a mandatory option"
    exit 1
else
    # create root dir and make sure it's group-writable (use if to avoid spending a long time with chown)
    if [[ ! -d $root ]]; then
        sudo mkdir -pv $root
        mygrp=$(groups | cut -f 1 -d " ")
        sudo chown -R $USER.$mygrp $root
    fi
fi

# Keep everything below unchanged
opt_root=$root/opt
tmp=$root/tmp/sicoe_env
mkdir -p $tmp

if [[ -z $keep_tmp ]]; then
    echo "Cleaning up $tmp directory ..."
    rm -rf $tmp
fi
modulefiles_root=$root/modulefiles
modulefiles_os_root=$root/modulefiles/$os
config_dir=$root/cfg
mkdir -p $opt_root
mkdir -p $tmp
mkdir -p $modulefiles_root
mkdir -p $modulefiles_os_root
mkdir -p $config_dir
config_file=$config_dir/sbruf.env.bash

# retrieve directory of the running script
script_dir=$(dirname "$(readlink -f "$0")")

if (( ENV_MOD == 1 )); then
    log_progress "ENV_MOD"

    # First of all, build and install a statically-linked version of Tcl
    cd $tmp
    wget https://sourceforge.net/projects/tcl/files/Tcl/8.6.13/tcl8.6.13-src.tar.gz/download -O tcl8.6.13-src.tar.gz 
    tar -xf tcl8.6.13-src.tar.gz
    cd tcl8.6.13/unix
    tcl_inst_dir=$opt_root/$os/modules/tcl
    mkdir -p $tcl_inst_dir
    ./configure --prefix=$tcl_inst_dir --enable-shared=no --enable-threads
    make install
    cd $tcl_inst_dir/bin && ln -s tclsh8.6 tclsh

    # Now take care of environment modules
    cd $tmp
    curl -LJO https://github.com/cea-hpc/modules/releases/download/v5.6.1/modules-5.6.1.tar.gz
    tar xfz modules-5.6.1.tar.gz
    cd modules-5.6.1

    # Ensure modules use our static tcl when installed. This way the static tclsh path will
    # be hardcoded in the module scripts (see SICOE-3)
    ./configure --prefix=$opt_root/$os/modules --with-tclsh=$tcl_inst_dir/bin/tclsh \
        --with-tclinclude=$tcl_inst_dir/include --with-tcl=$tcl_inst_dir/lib
    make install
fi

if (( PYTHON == 1 )); then
    log_progress "PYTHON"
    PYTHON_PACKAGES=1
    DONGLES_CH_PY=1
    py_maj_ver=3.13
    py_ver=3.13.3
    if (( PYTHON_DBG == 1 )); then 
        py_pfx=$opt_root/$os/python/${py_ver}.dbg
    else
        py_pfx=$opt_root/$os/python/$py_ver
    fi
    cd $tmp
    # download python, unzip, cd into directory
    wget https://www.python.org/ftp/python/$py_ver/Python-$py_ver.tgz 
    echo "Extracting tgz ..."
    tar zxf Python-$py_ver.tgz
    cd Python-$py_ver

    # build and install Python
    echo "Running configure ..."
    if (( PYTHON_DBG == 1 )); then
        ./configure --enable-shared --with-address-sanitizer --with-pydebug --prefix=$py_pfx --disable-ipv6
    else
        ./configure --enable-shared --enable-optimizations --prefix=$py_pfx
    fi
    make install

    # create virtual environment
    echo "Creating virtual env ..."
    cd $py_pfx
    export LD_LIBRARY_PATH=$PWD/lib:$LD_LIBRARY_PATH
    ./bin/python3 -m venv env/default

    # make sure virtual environment is in your path
    cd ~
    export PATH=$py_pfx/env/default/bin:${PATH}
    incl_dir=$(python3 -c "import sysconfig; print(sysconfig.get_paths()['include'])")

    # create modulefile
    mkdir -p $modulefiles_os_root/python
    cat << EOM > $modulefiles_os_root/python/$py_ver
#%Module
prepend-path PATH $opt_root/$os/python/$py_ver/env/default/bin
prepend-path LD_LIBRARY_PATH $opt_root/$os/python/$py_ver/env/default/lib
prepend-path LD_LIBRARY_PATH $opt_root/$os/python/$py_ver/lib
prepend-path CPATH $incl_dir
EOM
fi

if ((PYTHON_PACKAGES == 1)); then
    log_progress "PYTHON_PACKAGES"
   # # install pure-so cheetah sources and libs
   #  cp "$script_dir/tools/dongles/cheetah-api-linux-x86_64-v3.40.tar.gz" $tmp
   #  cd $tmp
   #  tar -xzf cheetah-api-linux-x86_64-v3.40.tar.gz
   #  
   #  # install pre-built cheetah Python module
   #  # If run on its own (which=filter), we assume the user has loaded
   #  # module load python before running the script. Let's make sure
   #  sitep_dir=$(python3 -c "import sysconfig; print(sysconfig.get_paths()['purelib'])")
   #  if [[ "$sitep_dir" == *"$opt_root"* ]]; then
   #      echo "Installing cheetah API for Python"
   #      cp $tmp/cheetah-api-linux-x86_64-v3.40/python/cheetah_py.py $sitep_dir
   #      cp $tmp/cheetah-api-linux-x86_64-v3.40/c/cheetah.so $sitep_dir
   #  else
   #      >&2 echo "Your current Python does not seem to match any sicoe env Python installation"
   #      >&2 echo "which python reports -> $(which python)"
   #      >&2 echo "site-packages would be -> $sitep_dir"
   #      >&2 echo "opt_root is -> $opt_root"
   #      >&2 echo "Please use module load python/x.y.z and re-run"
   #      exit 1
   #  fi
         
    # upgrade pip
    pip3 install --upgrade pip

    # install packages
    pip3 install setuptools==78.1.0
    pip3 install pandas
    pip3 install seaborn
    pip3 install pycryptodome
    pip3 install sip
    pip3 install PyQt5==5.13.1
    pip3 install QScintilla==2.11.2
    pip3 install ftd2xx
    pip3 install pyinstaller
    pip3 install ipython==9.1.0
    pip3 install prettytable
    pip3 install plotext
    pip3 install grapheme
    pip3 install python-pptx
    pip3 install python-docx
    pip3 install docx
    pip3 install pyflakes
    pip3 install alive_progress
    pip3 install bitstring==4.3.1
    pip3 install tqdm==4.67.1
    pip3 install dataframe-image
    pip3 install pytest
    pip3 install pytest-progress
    pip3 install compiledb
    pip3 install python-lsp-server
    pip3 install build
    pip3 install wheel
    pip3 install toml
    pip3 install icecream
    pip3 install distro
    pip3 install paramiko
    pip3 install scp
    pip3 install pyyaml
fi

py37_pfx=$opt_root/$os/python/3.7.4
if (( PYTHON37 == 1 )); then
    log_progress "PYTHON37"
    py37_pfx=$opt_root/$os/python/3.7.4
    DONGLES_PY37=1
    cd $tmp
    # download python 3.7.4, unzip, cd into directory
    wget https://www.python.org/ftp/python/3.7.4/Python-3.7.4.tgz
    echo "Extracting tgz ..."
    tar zxf Python-3.7.4.tgz
    cd Python-3.7.4

    # build and install Python
    ./configure --enable-shared --prefix=$py37_pfx
    make install

    # create virtual environment
    cd $py37_pfx
    export LD_LIBRARY_PATH=$PWD/lib:$LD_LIBRARY_PATH
    ./bin/python3 -m venv env/default

    # make sure virtual environment is in your path
    cd ~
    export PATH=$py37_pfx/env/default/bin:${PATH}

    # create modulefile
    mkdir -p $modulefiles_os_root/python
    cat << EOM > $modulefiles_os_root/python/3.7.4
#%Module
prepend-path PATH $opt_root/$os/python/3.7.4/env/default/bin
prepend-path LD_LIBRARY_PATH $opt_root/$os/python/3.7.4/env/default/lib
prepend-path LD_LIBRARY_PATH $opt_root/$os/python/3.7.4/lib
prepend-path CPATH $opt_root/$os/python/3.7.4/include/python3.7m
EOM
    cat << EOM > $modulefiles_os_root/python/.version
#%Module
set ModulesVersion "3.7.4"
EOM

    # upgrade pip
    pip3 install --upgrade pip

    # install packages
    pip3 install setuptools==68.0.0
    pip3 install pandas
    pip3 install seaborn
    pip3 install pycrypto
    pip3 install sip
    pip3 install PyQt5==5.13.1
    pip3 install QScintilla==2.11.2
    pip3 install ftd2xx
    pip3 install pyinstaller==5.6.2
    pip3 install ipython==7.34.0
    pip3 install prettytable
    pip3 install plotext
    pip3 install grapheme
    pip3 install python-pptx
    pip3 install python-docx
    pip3 install docx
    pip3 install pyflakes
    pip3 install alive_progress
    pip3 install bitstring==3.1.9
    pip3 install tqdm==4.64.1
    pip3 install dataframe-image
    pip3 install pytest
    pip3 install pytest-progress
    pip3 install compiledb
    pip3 install python-lsp-server
    pip3 install build
    pip3 install wheel
    pip3 install toml
    pip3 install icecream
fi


if (( CFG_FILE == 1 )); then
    log_progress "CFG_FILE"
    # populate config file to be sourced
    cat << EOM > $config_file
# Make sure we don't step into each other
umask 002

# Detect OS
os_rel=\$(cat /etc/os-release)
if [[ \$os_rel =~ 'NAME="Ubuntu"' && \$os_rel =~ 'VERSION_ID="20.04"' ]]; then
    os=ubu20
elif [[ \$os_rel =~ 'NAME="Ubuntu"' && \$os_rel =~ 'VERSION_ID="22.04"' ]]; then
    os=ubu22
elif [[ \$os_rel =~ 'NAME="Ubuntu"' && \$os_rel =~ 'VERSION_ID="24.04"' ]]; then
    os=ubu24
elif [[ \$os_rel =~ 'NAME="SLES"' && \$os_rel =~ 'VERSION_ID="12.5"' ]]; then
    os=suse12
elif [[ \$os_rel =~ 'NAME="SLES"' && \$os_rel =~ 'VERSION_ID="15.4"' ]]; then
    os=suse15
elif [[ \$os_rel =~ 'NAME="Rocky Linux"' && \$os_rel =~ 'VERSION_ID="8' ]]; then
    os=rocky8
elif [[ \$os_rel =~ 'NAME="Red Hat Enterprise Linux"' && \$os_rel =~ 'VERSION_ID="8.4"' ]]; then
    os=rhl8
else
    echo "Could not configure SBRUF env: Unknown OS!"
fi

# The following is needed by module load sstdev
export SICOE_ROOT_DIR=$root
export SICOE_TOOLS_DIR=$root/opt/\$os
export SICOE_PROJ_DIR=$root/proj/

# The following needed by end users to run sbruf env -s and -p 
export SBRUF_ROOT_DIR=$root/opt/common/sbruf
export SBRUF_BUILD_PUBLISHED_DIR=$root/opt/\$os/sicoe/published
export SBRUF_BUILD_SHARED_DIR=$root/opt/\$os/sicoe/shared
export SBRUF_DEPLOY_DIR=/opt/sicoe/deployed
export SBRUF_DEPLOY_HOST_FILE=\$SBRUF_ROOT_DIR/deploy_hosts.txt
export SBRUF_TARGET_AUDIENCE=enduser

# The following used by sbruf-deploy (and potentially other scripts)
export SBRUF_TMP_DIR=\$HOME/.sicoe/tmp
mkdir -p \$SBRUF_TMP_DIR

# The following used by sbruf-release
export SBRUF_RELEASE_DIR=\$SICOE_PROJ_DIR/stellar/release
mkdir -p \$SBRUF_RELEASE_DIR

# The following needed by end users to run tools such as coaster or gmebm
export SBRUF_SOCKET_DIR=\$HOME/.sicoe/sockets
mkdir -p \$SBRUF_SOCKET_DIR

# The following used by coastest to put regression logs
export SBRUF_REGR_RES_DIR=\$SICOE_PROJ_DIR/stellar/regr/\$USER
mkdir -p \$SBRUF_REGR_RES_DIR

# Add sbruf bash function to environment
sbruf ()
{
    if [[ \$1 == env ]]; then
        eval "\$(\$SBRUF_ROOT_DIR/sbruf \$@)" 2>&1
    else
        \$SBRUF_ROOT_DIR/sbruf \$@
    fi
    status=\$?
    if [[ \$status != 0 ]]; then
        >&2 printf "\\033[0;31m ** ERROR detected in sbruf **\\033[0m\n"
    fi
    return \$status
}
# make function available to scripts
export -f sbruf

# Export var containing this machine's os name as used by SBRUF config tools
export SBRUF_OS=\$os

# Configure the appropriate modulefiles (based on detected OS)
source $opt_root/\$os/modules/init/profile.sh
export MODULEPATH=$modulefiles_root/\$os:\${MODULEPATH}

export MODULES_REDIRECT_OUTPUT=1
# Add Python to the path so that end users can run coaster
# (arc shell will remove python from path causing havoc. This is fixed by unload + load)
module unload python
module load python
EOM
fi

# source config file so that module command is available to this script
echo "Sourcing sbruf config file ($config_file)"
source $config_file
echo "Done sourcing sbruf config file"

# Create directory tree
mkdir -p $SICOE_TOOLS_DIR
mkdir -p $SICOE_PROJ_DIR
mkdir -p $SICOE_PROJ_DIR/usr/
mkdir -p $SBRUF_ROOT_DIR
mkdir -p $SBRUF_BUILD_PUBLISHED_DIR
mkdir -p $SBRUF_BUILD_SHARED_DIR

rustup_home=$opt_root/$os/rust/rustup
cargo_home=$opt_root/$os/rust/cargo
if (( RUSTUP == 1 )); then
    log_progress "RUSTUP"
    # install rustup
    export RUSTUP_HOME=$rustup_home
    export CARGO_HOME=$cargo_home
    cd $tmp && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs > rustup-init
    chmod +x rustup-init
    ./rustup-init -y --no-modify-path --profile default --default-toolchain stable

    # create modulefile
    mkdir -p $modulefiles_os_root/rust/
    rust_modulefile=$modulefiles_os_root/rust/latest
    cat << EOM > $rust_modulefile
#%Module
prepend-path PATH $cargo_home/bin
setenv RUSTUP_HOME $rustup_home
setenv CARGO_HOME $cargo_home
EOM
fi

if (( RUST_APPS == 1 )); then
    module load rust

    log_progress "RUST_APPS: exa"
    mkdir -p $opt_root/$os/exa/
    cargo install exa
    mv $cargo_home/bin/exa $opt_root/$os/exa
    mkdir -p $modulefiles_os_root/exa
    cat << EOM > $modulefiles_os_root/exa/latest
#%Module
prepend-path PATH $opt_root/$os/exa
EOM

    log_progress "RUST_APPS: bat"
    mkdir -p $opt_root/$os/bat/
    cargo install bat
    mv $cargo_home/bin/bat $opt_root/$os/bat/
    mkdir -p $modulefiles_os_root/bat
    cat << EOM > $modulefiles_os_root/bat/latest
#%Module
prepend-path PATH $opt_root/$os/bat
EOM

    log_progress "RUST_APPS: btm"
    mkdir -p $opt_root/$os/btm/
    cargo install bottom
