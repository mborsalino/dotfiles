" Toggle trailing whitespace highlighting on/off
function! ToggleTrailingWhitespace()
    if g:trailing_ws_enabled
        " Clear match in all windows
        windo match none
        let g:trailing_ws_enabled = 0
        lua vim.notify("Trailing whitespace highlight OFF", vim.log.levels.INFO)
    else
        " Apply match in all windows
        windo match TrailingWhitespace /\s\+\%#\@<!$/
        let g:trailing_ws_enabled = 1
        lua vim.notify("Trailing whitespace highlight ON", vim.log.levels.INFO)
    endif
endfunction

