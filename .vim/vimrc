" Highlight trailing whitespace with a subtle dark grey background.
" Uses match instead of set list so tabs aren't affected.
" The \%#\@<! avoids highlighting while typing at end of line.
" Applied via autocmd so it persists across buffer/window switches
" (match is window-local and gets cleared otherwise).
highlight TrailingWhitespace guibg=#444444 ctermbg=238
let g:trailing_ws_enabled = 1

function! ApplyTrailingWhitespace()
    " Only apply to normal file buffers (skip plugin UIs, popups, terminals)
    if g:trailing_ws_enabled && &buftype ==# ''
        match TrailingWhitespace /\s\+\%#\@<!$/
    else
        match none
    endif
endfunction

augroup TrailingWS
    autocmd!
    autocmd BufWinEnter,WinEnter * call ApplyTrailingWhitespace()
    autocmd ColorScheme * highlight TrailingWhitespace guibg=#444444 ctermbg=238 | call ApplyTrailingWhitespace()
augroup END

" Apply immediately for the first window
call ApplyTrailingWhitespace()

